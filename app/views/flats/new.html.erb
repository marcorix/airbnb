<div class="container py-5">
  <div class="row">
    <div class="col-12 col-md-6 offset-lg-3">
      <div class="bg-white bor-rad p-3 shadow">
        <h3>Create a new list</h3>
        <%= simple_form_for @flat do |f| %>
          <%= f.input :name, placeholder: 'Cosy House' %>
          <%= f.input :guests %>
          <%= f.input :country %>
          <%= f.input :city %>
          <%= f.input :bedrooms %>
          <%= f.input :beds %>
          <%= f.input :price %>
          <%= f.input :description %>
          <%= f.input :photos, as: :file, input_html: { multiple: true } %>
          <%= f.submit class: 'btn btn-ghost' %>
        <% end %>
      </div>
    </div>
  </div>
</div>
