<div class="container mt-3">
  <div class="row">
    <div class="col-12">
      <h1>All our Flats</h1>
    </div>
  </div>

  <div class="row">
    <div class="cards">
      <% @flats.each do |flat| %>
        <%= render 'flat_card' , flat: flat %>
      <% end %>
    </div>
  </div>

  <%# Mapbox %>
  <div style='width: 100%; height: 300px;'
       data-controller="map"
       data-map-api-key-value="<%= ENV['MAPBOX_API_KEY']%>"
       data-map-markers-value="<%= @markers.to_json %>"></div>
</div>
