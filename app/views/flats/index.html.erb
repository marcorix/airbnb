<div class="container mt-3">
  <div class="row">
    <div class="col-12">
      <h1>All our Flats <i class="fa-solid fa-square-plus"></i></h1>
    </div>

    <div class="search-field w-50">
      <%= form_tag flats_path, method: :get, class: "d-flex" do %>
        <%= select_tag :country, options_for_select(ISO3166::Country.all, "Country"), :include_blank => 'Select a country'%>
        <%= label_tag 'wifi' %>
        <%= radio_button_tag 'wifi', 'true' %>
        <%= label_tag 'guests' %>
        <%= select_tag :card, options_for_select([ "VISA", "MasterCard" ], "MasterCard") %>
        <%= number_field_tag 'quantity', nil, in: 1...100 %>
        <%= submit_tag "Search", class: "btn btn-primary" %>
      <% end %>
    </div>

  </div>

   <br>

  <div class="row">
    <div class="cards">
      <% @flats.each do |flat| %>
        <%= render 'flat_card' , flat: flat %>
      <% end %>
    </div>
  </div>
  <hr>
  <%# Mapbox %>
  <div style='width: 100%; height: 300px;'
       data-controller="map"
       data-map-api-key-value="<%= ENV['MAPBOX_API_KEY']%>"
       data-map-markers-value="<%= @markers.to_json %>"></div>
</div>
